.hero {
  padding-top: 120px;
  padding-bottom: 120px;
}

.archive-status {
  color: #888;
  letter-spacing: 2px;
  font-size: 12px;
  margin-bottom: 40px;
}

.hero-title {
  font-size: clamp(64px, 10vw, 140px);
  line-height: 0.95;
  font-weight: 700;
  margin-bottom: 40px;
}

.hero-subtitle {
  font-size: 28px;
  margin-bottom: 12px;
}

.hero-description {
  color: #888;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 80px;
  margin-bottom: 120px;
}

.stat-card {
  border: 1px solid #1f1f1f;
  padding: 24px;
}

.stat-card span {
  display: block;
  color: #777;
  font-size: 11px;
  letter-spacing: 2px;
}

.stat-card h2 {
  margin-top: 16px;
  font-size: 36px;
}

.collection-section {
  margin-bottom: 120px;
}

.collection-section h3 {
  margin-bottom: 24px;
  letter-spacing: 2px;
  font-size: 12px;
}

.collection-card {
  display: block;
  border: 1px solid #1f1f1f;
  padding: 40px;
  text-decoration: none;
  color: inherit;
}

.collection-card:hover {
  border-color: #555;
}

.collection-label {
  font-size: 32px;
  margin-bottom: 40px;
}

.collection-meta {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.collection-meta span {
  color: #777;
  font-size: 11px;
  letter-spacing: 2px;
}

.collection-enter {
  margin-top: 40px;
  letter-spacing: 2px;
}
@import "tailwindcss";

:root {
  --background: #000000;
  --foreground: #ffffff;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 48px;
}

.archive-nav {
  display: flex;
  gap: 24px;
  padding: 24px 48px;
  border-bottom: 1px solid #222;
}

.archive-nav a {
  color: white;
  text-decoration: none;
  font-size: 12px;
  letter-spacing: 2px;
}

.archive-nav a:hover {
  opacity: 0.7;
}

.archive-home {
  display: flex;
  flex-direction: column;
  gap: 120px;
  padding-bottom: 120px;
}

.archive-status-bar {
  font-size: 11px;
  letter-spacing: 2px;
  color: #888;
  padding-bottom: 16px;
}

.hero h1 {
  font-size: clamp(56px, 8vw, 110px);
  line-height: 1;
  margin-bottom: 16px;
}

.doctrine {
  font-size: 22px;
  color: #d0d0d0;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid #222;
  border-bottom: 1px solid #222;
  text-align: center;
}

.status-grid div {
  padding: 32px 16px;
  border-right: 1px solid #222;
}

.status-grid div:last-child {
  border-right: none;
}

.label {
  display: block;
  font-size: 11px;
xx  letter-spacing: 2px;
  color: #777;
  margin-bottom: 8px;
}

.status-grid h2 {
  font-size: 42px;
}

.archive-panel {
  border: 1px solid #222;
  padding: 48px 32px;
}

.panel-header {
  font-size: 11px;
  letter-spacing: 2px;
  color: #777;
  margin-bottom: 24px;
}

.archive-panel h3 {
  font-size: 32px;
  margin-bottom: 16px;
}

.archive-link {
  display: inline-block;
  margin-top: 24px;
  text-decoration: none;
  color: white;
  letter-spacing: 1.5px;
}

.archive-sections {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid #222;
  margin-top: 40px;
}

.archive-sections a {
  padding: 48px 16px;
  text-decoration: none;
  color: white;
  letter-spacing: 2px;
  border-right: 1px solid #222;
  text-align: center;
}

.archive-sections a:last-child {
  border-right: none;
}

.archive-sections a:hover {
  background: #111;
}

@media (max-width: 900px) {
  .status-grid {
    grid-template-columns: 1fr 1fr;
  }

  .archive-sections {
    grid-template-columns: 1fr 1fr;
  }
}

.archive-header {
  margin-bottom: 60px;
}

.archive-header span {
  font-size: 11px;
  letter-spacing: 2px;
  color: #777;
}

.archive-header h1 {
  margin-top: 16px;
  font-size: 72px;
}

.record-list {
  display: grid;
  gap: 16px;
}

.record-card {
  display: block;
  border: 1px solid #222;
  padding: 24px;
  text-decoration: none;
  color: white;
  transition: 0.2s;
}

.record-card:hover {
  background: #0d0d0d;
}

.record-card span {
  font-size: 11px;
  letter-spacing: 2px;
  color: #777;
}

.record-card h3 {
  margin-top: 12px;
  margin-bottom: 8px;
  font-size: 24px;
}

.record-meta {
  display: flex;
  gap: 24px;
  margin-bottom: 24px;
  color: #777;
  font-size: 11px;
  letter-spacing: 2px;
}

.record-body {
  margin-top: 40px;
  border-top: 1px solid #222;
  padding-top: 40px;
  line-height: 1.8;
}

.record-dossier {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid #222;
  border-bottom: 1px solid #222;
  margin-bottom: 60px;
}

.record-dossier div {
  padding: 24px;
  border-right: 1px solid #222;
}

.record-dossier div:last-child {
  border-right: none;
}

.record-dossier span {
  display: block;
  font-size: 11px;
  letter-spacing: 2px;
  color: #777;
  margin-bottom: 8px;
}

.record-dossier p {
  color: #fff;
}

.record-body {
  margin-top: 40px;
  border-top: 1px solid #222;
  padding-top: 40px;
  line-height: 2;
  white-space: pre-wrap;
  max-width: 800px;
}

.record-navigation {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 80px;
}

.record-nav-card {
  border: 1px solid #222;
  padding: 24px;
  text-decoration: none;
  color: white;
  letter-spacing: 2px;
}

.record-nav-card:hover {
  background: #111;
}

.archive-footer {
  margin-top: 120px;
  padding: 40px;
  border-top: 1px solid #222;
  display: flex;
  justify-content: space-between;
  color: #666;
  font-size: 11px;
  letter-spacing: 2px;
}

@media (max-width: 900px) {
  .archive-footer {
    flex-direction: column;
    gap: 12px;
  }
}

.record-markdown {
  max-width: 850px;
  margin: 0 auto;
  line-height: 2;
}

.record-markdown h1 {
  font-size: 56px;
  margin-bottom: 32px;
}

.record-markdown h2 {
  margin-top: 48px;
  margin-bottom: 24px;
}

.record-markdown p {
  margin-bottom: 16px;
}

.record-markdown hr {
  border-color: #222;
  margin: 48px 0;
}

.collection-progress {
  margin-top: 24px;
  color: #777;
  letter-spacing: 2px;
  font-size: 11px;
}
